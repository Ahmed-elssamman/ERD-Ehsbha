NODE_ENV=development
PORT=4000

# === Database (Neon Postgres recommended) ===
# DATABASE_URL  = POOLED endpoint  (hostname contains "-pooler") — used at runtime
# DIRECT_URL    = DIRECT endpoint  (no "-pooler" in hostname)    — used by Prisma for migrations
#
# Both are NOT the same as the Neon Data API REST URL (which has ".apirest." in the hostname
# and starts with "https://"). Prisma needs the "postgresql://" form.
#
# For Neon: console.neon.tech → project → "Connection string" tab.
#   - "Pooled connection" toggle ON  → DATABASE_URL
#   - "Pooled connection" toggle OFF → DIRECT_URL
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require

# Use at least 32 random characters per secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_with_strong_random_string_64_chars
JWT_REFRESH_SECRET=replace_me_with_another_strong_random_string_64_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Comma-separated origins, or "*" for local dev.
# Production should be locked down to your web origin (e.g. https://app.ehsbha.com).
CORS_ORIGINS=*

# === SMTP (transactional email) ===
# Gmail example (recommended for small projects):
#   1. Turn on 2-Step Verification: https://myaccount.google.com/security
#   2. Generate an App Password:    https://myaccount.google.com/apppasswords
#      → "Other (custom name)" → name it "Ehsbha backend" → copy the 16-char code.
#   3. Paste below WITHOUT spaces (or with — both work).
# SMTP_FROM MUST match SMTP_USER for Gmail's SPF/DKIM to align (otherwise mail lands in spam).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=Ehsbha <you@gmail.com>
# Optional: where reply-to should land (defaults to SMTP_USER).
# SMTP_REPLY_TO=support@yourdomain.com

APP_PUBLIC_NAME=Ehsbha
APP_PUBLIC_URL=https://ehsebha.modev.me

# === OCR — Azure AI Vision (trip screenshot extraction) ===
# Backed by an Azure AI multi-service Cognitive Services resource that hosts
# BOTH Image Analysis 4.0 (Read OCR — lines/words/bboxes/confidence,
# multilingual incl. Arabic) and Document Intelligence (prebuilt-receipt
# model). One endpoint + one key for both.
#
# Provision: Azure Portal → "Azure AI services" multi-service resource →
# East US (or your region) → Keys and Endpoint.
#
# DO NOT commit real keys. Store them in backend/.env (which is gitignored)
# and rotate periodically via the portal's "Regenerate Key" button.
AZURE_VISION_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com/
AZURE_VISION_KEY=replace_me_with_the_real_key
AZURE_VISION_REGION=eastus
# When true, ride-hailing screenshots are additionally analyzed by the
# Document Intelligence prebuilt-receipt model and the result is merged with
# the Read OCR. Adds latency + cost but improves accuracy on bundled fare /
# tax / total fields. Turn off to fall back to Read OCR + semantic parsing.
#
# Document Intelligence is a SEPARATE service from Computer Vision in Azure.
# A single-service "Computer Vision" resource WILL 401 on DI calls — to use
# DI you must either:
#   (a) provision a separate "Document Intelligence" resource (recommended) —
#       set AZURE_DOC_INTELLIGENCE_ENDPOINT + AZURE_DOC_INTELLIGENCE_KEY below
#   (b) re-create the AI resource as the multi-service "Azure AI services"
#       SKU which includes both Vision and Document Intelligence — leave the
#       *_DOC_*_ env vars unset and the client falls back to AZURE_VISION_*.
AZURE_DOC_INTELLIGENCE_ENABLED=false
# AZURE_DOC_INTELLIGENCE_ENDPOINT=https://YOUR-DI-RESOURCE.cognitiveservices.azure.com/
# AZURE_DOC_INTELLIGENCE_KEY=replace_me
