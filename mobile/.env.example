# Where the mobile app should reach the backend API.
#
# Pick the right value for HOW you're running the app:
#
#   Web preview (npm run web)        →  http://localhost:4000/api/v1
#   Android emulator                 →  http://10.0.2.2:4000/api/v1
#   iOS simulator                    →  http://localhost:4000/api/v1
#   Physical phone (Expo Go)         →  http://<your-PC-LAN-IP>:4000/api/v1
#                                       e.g. http://192.168.1.6:4000/api/v1
#
# To find your PC's LAN IP on Windows:  ipconfig  (look for "IPv4 Address")
# Your phone MUST be on the same Wi-Fi as your PC.

EXPO_PUBLIC_API_URL=http://10.0.2.2:4000/api/v1
